# Dev dependencies — reinstalled inside the build stages
node_modules/
vendor/

# Built assets — produced by the frontend stage
public/build/

# Vite dev server indicator (must not exist in production)
public/hot

# Storage symlink — recreated by entrypoint via `artisan storage:link`
public/storage

# Git history
.git/
.gitignore
.gitattributes

# Local env — never bake secrets into the image
.env
.env.*
!.env.example

# User data — should live in Docker volumes, not the image
storage/app/sender.json
storage/app/recipients.json
storage/app/invoice_counter.json
storage/app/public/
storage/logs/
storage/pail/
database/database.sqlite

# Framework caches — regenerated by entrypoint
bootstrap/cache/

# IDE / OS noise
.idea/
.vscode/
*.DS_Store
Thumbs.db
